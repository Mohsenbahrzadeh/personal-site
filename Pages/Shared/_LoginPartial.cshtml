@using Microsoft.AspNetCore.Identity
@using PersonalSite.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <a asp-area="Identity" asp-page="/Account/Manage/Index" title="مدیریت حساب">سلام، @(User.Identity!.Name)</a>
    @if (User.IsInRole("Admin"))
    {
        <a asp-area="" asp-page="/Admin/Index">پنل مدیریت</a>
    }
    <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })" style="display:inline">
        <button type="submit">خروج</button>
    </form>
}
else
{
    <a asp-area="Identity" asp-page="/Account/Register">ثبت‌نام</a>
    <a asp-area="Identity" asp-page="/Account/Login">ورود</a>
}
